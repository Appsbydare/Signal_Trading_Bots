# Normalize all text files to LF in the repo, checkout as-is on all platforms
* text=auto eol=lf

# Explicitly force LF for web source files
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.env  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binary files — never touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
